// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Subject {
  MATH
  PHYSICS
  CHEMISTRY
}

enum Phase {
  LOCAL
  COUNTY
  NATIONAL
}

enum ContestStage {
  LOCAL
  COUNTY
  NATIONAL
  SELECTION
  FINAL_ROUND
  INTERNATIONAL
  OTHER
}

enum SubmissionStatus {
  PENDING
  BLURRY_REJECTED
  GRADED
  FAILED
}

enum UserRole {
  STUDENT
  TEACHER
  OTHER
}

enum ProblemStatus {
  DRAFT
  PUBLISHED
}

enum CommentReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  FOLLOWED_YOU
  FOLLOWING_USER_SUBMITTED
  NEW_PROBLEM_PUBLISHED
}

/// Tone for AI-written feedback only. Does not relax scoring or rubric application.
enum AiTeacherStyle {
  STRICT_OLYMPIAD_JUDGE
  SUPPORTIVE_TEACHER
  DETAILED_TUTOR
  FUNNY_LIGHTHEARTED
  EDUCATIONAL_MENTOR
  COMPETITION_COACH
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  emailVerified Boolean @default(false)
  firstName    String   @default("")
  lastName     String   @default("")
  country      String   @default("")
  city         String   @default("")
  school       String   @default("")
  bio          String   @default("")
  avatarUrl    String?
  preferredLanguage String @default("")
  roleLabel    UserRole @default(STUDENT)
  aiTeacherStyle AiTeacherStyle @default(SUPPORTIVE_TEACHER)
  usernameChangedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions Submission[]
  comments    Comment[]

  following Follow[] @relation("following")
  followers Follow[] @relation("followers")
  problemRatings ProblemRating[]
  authoredProblems Problem[] @relation("AuthoredProblems")
  authoredContestSets ContestSet[] @relation("AuthoredContestSets")
  commentReactions CommentReaction[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsTriggered Notification[] @relation("NotificationActor")
  contestSetProblemRatings ContestSetProblemRating[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]

  @@index([username])
  @@index([email])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Problem {
  id         String   @id @default(cuid())
  title      String
  summary    String?  @db.Text
  statement  String   @db.Text
  subject    Subject
  difficulty Int
  year       Int
  class      Int
  phase      Phase
  officialSolution  String   @db.Text @default("")
  gradingRubric     String   @db.Text @default("")
  extractedRubricText String? @db.Text
  extractedRubricTextUpdatedAt DateTime?
  maxScore          Int      @default(100)
  expectedConcepts  String[] @default([])
  status            ProblemStatus @default(PUBLISHED)
  publishedAt       DateTime?
  createdById       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author      User?                 @relation("AuthoredProblems", fields: [createdById], references: [id], onDelete: SetNull)
  rubricItems ProblemRubricItem[]
  attachments ProblemAttachment[]
  submissions Submission[]
  comments    Comment[]
  problemRatings ProblemRating[]

  @@index([subject, year, class, phase])
  @@index([status])
  @@index([createdById])
}

model ContestSet {
  id                  String        @id @default(cuid())
  title               String
  subject             Subject
  competitionName     String
  year                Int
  class               Int
  stage               ContestStage
  source              String?       @db.Text
  summary             String?       @db.Text
  statementMode       String        @default("PDF_ONLY")
  statementDisplayMode String       @default("PDF_FIRST")
  statementText       String?       @db.Text
  statementPdfUrl     String?
  rubricPdfUrl        String?
  rubricText          String?       @db.Text
  leaderboardPdfUrl   String?
  status              ProblemStatus @default(DRAFT)
  publishedAt         DateTime?
  createdById         String?
  totalProblemCount   Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  author      User?                 @relation("AuthoredContestSets", fields: [createdById], references: [id], onDelete: SetNull)
  problems    ContestSetProblem[]
  attachments ContestSetAttachment[]

  @@index([subject, year, class, stage])
  @@index([status])
  @@index([createdById])
}

model ContestSetProblem {
  id                    String      @id @default(cuid())
  contestSetId          String
  orderNumber           Int
  title                 String
  shortSummary          String?     @db.Text
  maxScore              Int         @default(100)
  extractedRubricText   String?     @db.Text
  extractedRubricTextUpdatedAt DateTime?
  statementTextOverride String?     @db.Text
  solutionText          String?     @db.Text
  aiRubricJson          String?     @db.Text
  isListedIndividually  Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  contestSet ContestSet @relation(fields: [contestSetId], references: [id], onDelete: Cascade)
  submissions Submission[]
  ratings     ContestSetProblemRating[]

  @@unique([contestSetId, orderNumber])
  @@index([contestSetId, orderNumber])
}

model ContestSetProblemRating {
  id                  String   @id @default(cuid())
  userId              String
  contestSetProblemId String
  ratingValue         Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contestSetProblem ContestSetProblem @relation(fields: [contestSetProblemId], references: [id], onDelete: Cascade)

  @@unique([userId, contestSetProblemId])
  @@index([contestSetProblemId])
  @@index([userId])
}

model ContestSetAttachment {
  id           String   @id @default(cuid())
  contestSetId String
  fileUrl      String
  fileType     String
  mimeType     String
  originalName String
  role         String   @default("SUPPORTING")
  problemOrderNumber Int?
  problemAssetType   String?
  caption      String?  @default("")
  sortOrder    Int      @default(0)
  uploadedAt   DateTime @default(now())

  contestSet ContestSet @relation(fields: [contestSetId], references: [id], onDelete: Cascade)

  @@index([contestSetId, sortOrder])
  @@index([contestSetId, role, problemOrderNumber, sortOrder])
}

model ProblemRubricItem {
  id          String   @id @default(cuid())
  problemId   String
  title       String
  description String   @db.Text
  points      Int
  orderIndex  Int      @default(0)
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, orderIndex])
}

model ProblemAttachment {
  id           String   @id @default(cuid())
  problemId    String
  fileUrl      String
  fileType     String
  mimeType     String
  originalName String
  caption      String?  @default("")
  role         String   @default("OTHER")
  sortOrder    Int      @default(0)
  uploadedAt   DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, sortOrder])
  @@index([problemId, role])
}

/// User rating 1–10 (integer; same value in API and UI).
model ProblemRating {
  id          String   @id @default(cuid())
  userId      String
  problemId   String
  ratingValue Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([problemId])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String?
  contestSetProblemId String?
  score     Int      @default(0)
  imageUrl  String
  extraImageUrls String? @db.Text
  status    SubmissionStatus @default(PENDING)
  aiScore   Int?
  aiFeedback String? @db.Text
  aiBreakdown Json?
  imageQualityReason String?
  reviewedAt DateTime?
  ocrExtractedText String? @db.Text
  visibilityUnlocked Boolean @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  contestSetProblem ContestSetProblem? @relation(fields: [contestSetProblemId], references: [id], onDelete: Cascade)

  @@index([problemId, aiScore])
  @@index([problemId, status])
  @@index([contestSetProblemId, aiScore])
  @@index([contestSetProblemId, status])
  @@index([userId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  parentCommentId String?
  body      String   @db.Text
  imageUrl  String?
  containsSpoiler Boolean @default(false)
  isFlagged Boolean  @default(false)
  editedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")
  reactions CommentReaction[]

  @@index([problemId, createdAt])
  @@index([parentCommentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  type      CommentReactionType
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}


model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  actorUserId     String?
  type            NotificationType
  title           String
  body            String           @db.Text
  targetUrl       String?
  relatedProblemId String?
  relatedSubmissionId String?
  relatedCommentId String?
  eventKey        String?          @unique
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  user  User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User?  @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}
