# PostgreSQL (local example)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maphy?schema=public"

# Auth (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# AI grading (required for submissions to be graded)
OPENAI_API_KEY="sk-..."
# Optional override (default in code: gpt-4o)
# OPENAI_GRADING_MODEL="gpt-4o"

# Gemini (used for rubric generation — better PDF/formula understanding)
GEMINI_API_KEY="AIza..."
# Optional override (default in code: gemini-2.0-flash)
# GEMINI_RUBRIC_MODEL="gemini-2.0-flash"

# Email verification (leave blank to log verification links to console instead)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@example.com"

# Base URL used for email links (defaults to http://localhost:3000)
NEXT_PUBLIC_BASE_URL="https://maphy.ro"
